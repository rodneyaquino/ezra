# =============================================================================
# Ezra Booking Automation | Local Environment Template
# =============================================================================
#
# This file is the starter template for local environment setup.
# The idea is simple: keep real URLs, usernames, and passwords out of the code,
# and place them in one local file that each person can fill in safely.
#
# HOW TO USE THIS FILE
# 1. Copy `.env.example` to `.env`
# 2. Replace the placeholder values with the real Ezra environment values
# 3. Keep `.env` private and never commit it
#
# WHY THIS FILE MATTERS
# - It keeps secrets out of the repo
# - It makes the suite easier to move between environments
# - It makes the first setup step easy for a reviewer to follow
# =============================================================================

# =============================================================================
# Member Facing Portal values
# =============================================================================
# BASE_URL is the main website for the booking flow.
# Example idea: 
BASE_URL=https://<base-url>

# BOOKING_START_PATH is the page path where the booking flow begins.
# In this project, the default starting point is the scan-selection step.
BOOKING_START_PATH=/sign-up/select-plan

# =============================================================================
# Ezra API value
# =============================================================================
# API_BASE_URL is used after booking succeeds.
# The suite calls the members API to figure out which member just booked,
# then uses that identity in the User Facing Portal check.
API_BASE_URL=https://<api-base-url>

# =============================================================================
# User Facing Portal values
# =============================================================================
# USER_PORTAL_BASE_URL is the second portal used for downstream status verification.
# This is where the suite signs in and checks the member's final status.
USER_PORTAL_BASE_URL=https://<user-portal-url>

# USER_PORTAL_USERNAME is the username or email used to log in to the
# User Facing Portal.
USER_PORTAL_USERNAME=<username>

# USER_PORTAL_PASSWORD is the password used to log in to the
# User Facing Portal.
USER_PORTAL_PASSWORD=<password>

# =============================================================================
# Status-wait value
# =============================================================================
# USER_PORTAL_ACTIVE_TIMEOUT_MS tells the suite how long it should keep checking
# for the member record to become Active.
#
# This matters because the second portal may need a short delay before it shows
# the newest booking state.
USER_PORTAL_ACTIVE_TIMEOUT_MS=90000
